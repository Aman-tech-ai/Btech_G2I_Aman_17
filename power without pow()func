#include <stdio.h>

int power(int a, int b) {
    if (b == 0)
        return 1;

    int p = a * power(a, b - 1);
    return p;
}

int main() {
    int a, b, p;

    printf("Enter the base : ");
    scanf("%d", &a);

    printf("Enter the exponent : ");
    scanf("%d", &b);

    p = power(a, b);

    printf("%d", p);

    return 0;
}